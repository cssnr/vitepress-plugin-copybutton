{
  "name": "@cssnr/vitepress-plugin-copybutton",
  "version": "0.0.1",
  "description": "VitePress Plugin to easily add a copy button to a heading, table, code snippet or text with automatic detection or pass any string.",
  "keywords": [
    "vitepress-plugin",
    "vitepress",
    "plugin",
    "copy",
    "button"
  ],
  "homepage": "https://github.com/cssnr/vitepress-plugin-copybutton",
  "bugs": {
    "url": "https://github.com/cssnr/vitepress-plugin-copybutton/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cssnr/vitepress-plugin-copybutton.git"
  },
  "funding": {
    "type": "ko-fi",
    "url": "https://ko-fi.com/cssnr"
  },
  "license": "GPL-3.0-only",
  "author": {
    "name": "Shane",
    "url": "https://cssnr.github.io/"
  },
  "exports": {
    ".": {
      "import": "./dist/CopyButton.es.js",
      "require": "./dist/CopyButton.umd.js",
      "types": "./dist/CopyButton.vue.d.ts"
    },
    "./style.css": "./dist/CopyButton.css"
  },
  "main": "dist/CopyButton.umd.js",
  "module": "dist/CopyButton.es.js",
  "types": "dist/CopyButton.vue.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc",
    "docs": "npm run docs:dev",
    "docs:build": "vitepress build docs",
    "docs:deploy": "npm run get-contributors && npm run docs:build",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "get-contributors": "npx get-contributors cssnr/vitepress-plugin-copybutton -f docs/.vitepress/contributors.json",
    "prepare": "npm run build",
    "prettier:check": "npx prettier --check .",
    "prettier:write": "npx prettier --write .",
    "yamllint": "yamllint -c .github/yamllint.yaml ."
  },
  "devDependencies": {
    "@cssnr/vitepress-plugin-contributors": "^0.2.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "prettier": "^3.8.3",
    "vite": "^8.0.9",
    "vitepress": "^1.6.4",
    "vitepress-plugin-group-icons": "^1.7.5",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.7"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  }
}
